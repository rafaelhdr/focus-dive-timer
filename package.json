{
  "name": "focusdive-monorepo",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "pnpm --filter focusdive_web dev",
    "web:build": "pnpm --filter focusdive_web build",
    "web:start": "pnpm --filter focusdive_web start",
    "web:lint": "pnpm --filter focusdive_web lint",
    "web:typecheck": "pnpm --filter focusdive_web typecheck",

    "dev": "pnpm run web:dev",
    "build": "pnpm run web:build",
    "start": "pnpm run web:start"
  }
}
