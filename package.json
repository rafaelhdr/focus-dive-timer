{
  "name": "focusdive-monorepo",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "dotenv -e .env -- pnpm --filter @focusdive/webapp dev",
    "web:build": "dotenv -e .env -- pnpm --filter @focusdive/webapp build",
    "web:start": "pnpm --filter @focusdive/webapp start",
    "web:lint": "pnpm --filter @focusdive/webapp lint",
    "web:typecheck": "pnpm --filter @focusdive/webapp typecheck",

    "extension:dev": "dotenv -e .env -- pnpm --filter @focusdive/extension dev",
    "extension:build": "dotenv -e .env -- pnpm --filter @focusdive/extension build", 
    "extension:build:dev": "pnpm --filter @focusdive/extension build:dev",

    "dev": "pnpm run web:dev",
    "build": "pnpm run web:build",
    "start": "pnpm run web:start"
  }
}
