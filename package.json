{
  "name": "focusdive-monorepo",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "web:dev": "dotenv -e .env -- pnpm --filter @focusdive/webapp dev",
    "web:build": "dotenv -e .env -- pnpm --filter @focusdive/webapp build",
    "web:start": "pnpm --filter @focusdive/webapp start",
    "web:typecheck": "pnpm --filter @focusdive/webapp typecheck",
    "extension:dev": "dotenv -e .env -- pnpm --filter @focusdive/extension dev",
    "extension:build:firefox": "BUILD_TARGET=extension dotenv -e .env -- pnpm --filter @focusdive/extension build && cp apps/extension/manifest.firefox.json apps/extension/dist/manifest.json",
    "extension:build:chrome": "BUILD_TARGET=extension dotenv -e .env -- pnpm --filter @focusdive/extension build && cp apps/extension/manifest.chrome.json apps/extension/dist/manifest.json",
    "extension:build:dev": "pnpm --filter @focusdive/extension build:dev",
    "dev": "pnpm run web:dev",
    "build": "pnpm run web:build",
    "start": "pnpm run web:start"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
