          }
        },
        "type": "object",
        "required": [
          "is_connected"
        ],
        "title": "SlackStatusOut"
      },
      "SlackTestIn": {
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "start",
              "stop"
            ],
            "title": "Action"
          },
          "dnd_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dnd Text"
          },
          "dnd_emoji": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dnd Emoji"
          }
        },
        "type": "object",
        "required": [
          "action"
        ],
        "title": "SlackTestIn"
      },
      "SlackTestOut": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "success"
        ],
        "title": "SlackTestOut"
      },
