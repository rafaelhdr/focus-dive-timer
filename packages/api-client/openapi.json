        "properties": {
          "is_running": {
            "type": "boolean",
            "title": "Is Running"
          },
          "ends_at": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ends At"
          },
          "mode": {
            "type": "string",
            "enum": [
              "focus",
              "break"
            ],
            "title": "Mode"
          },
          "remaining_time": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Remaining Time"
          }
        },
        "type": "object",
        "required": [
          "is_running",
          "ends_at",
          "mode",
          "remaining_time"
        ],
        "title": "TimerInOut"
      },
      "UserPreferencesInOut": {
        "properties": {
          "alarm_sound": {
            "type": "string",
            "enum": [
              "minimalistic",
              "wooden",
              "snappy",
              "level"
            ],
            "title": "Alarm Sound",
            "default": "minimalistic"
          },
          "focus_beep_enabled": {
            "type": "boolean",
            "title": "Focus Beep Enabled",
            "default": true
          },
          "focus_beep_volume": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 0.0,
            "title": "Focus Beep Volume",
            "default": 1
          },
          "autostart_focus": {
            "type": "boolean",
            "title": "Autostart Focus",
            "default": true
          },
          "autostart_break": {
            "type": "boolean",
            "title": "Autostart Break",
            "default": true
          },
          "default_focus_duration": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Default Focus Duration",
            "default": 25
          },
          "default_break_duration": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Default Break Duration",
            "default": 5
          }
        },
        "type": "object",
        "title": "UserPreferencesInOut"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VerifyIn": {
        "properties": {
          "token": {
            "type": "string",
            "maxLength": 6,
            "minLength": 6,
            "title": "Token"
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "token",
          "email"
        ],
        "title": "VerifyIn"
      },
      "VerifyOut": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "refresh_token": {
            "type": "string",
            "title": "Refresh Token"
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "refresh_token"
        ],
        "title": "VerifyOut"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
