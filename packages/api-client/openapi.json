            "type": "boolean",
            "title": "Slack Enabled"
          },
          "slack_dnd_emoji": {
            "type": "string",
            "title": "Slack Dnd Emoji"
          },
          "slack_dnd_text": {
            "type": "string",
            "title": "Slack Dnd Text"
          }
        },
        "type": "object",
        "required": [
          "slack_enabled",
          "slack_dnd_emoji",
          "slack_dnd_text"
        ],
        "title": "SlackPreferencesInOut"
      },
      "SlackStatusOut": {
        "properties": {
